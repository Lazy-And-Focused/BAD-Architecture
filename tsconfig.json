{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2024",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "f@/env": ["./src/services/env.service"],

      "@/services/*": ["./src/services/*"],
      "@/services": ["./src/services"],
      
      "@1/*": ["./src/v1/*"],
      
      "@1/constants/*": ["./src/v1/constants/*"],
      "@1/constants": ["./src/v1/constants"],

      "@1/utils/*": ["./src/v1/utils/*"],
      "@1/utils": ["./src/v1/utils"],
      
      "@1/errors/*": ["./src/v1/errors/*"],
      "@1/errors": ["./src/v1/errors"],
      
      "@1/services/*": ["./src/v1/services/*"],
      "@1/services": ["./src/v1/services"],
      
      "@1/decorators/*": ["./src/v1/decorators/*"],
      "@1/decorators": ["./src/v1/decorators"],
      
      "@1/guards/*": ["./src/v1/guards/*"],
      "@1/guards": ["./src/v1/guards"],

      "@1/types/*": ["./src/v1/types/*"],
      "@1/types": ["./src/v1/types"],
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist", "bad-fockarch"]
}
