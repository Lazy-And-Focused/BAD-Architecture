  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "init": "tsc ./initialize/index.ts --outDir ./dist && node ./dist/index.js",
    "swagger": "set PROGRAM_MODE=swagger&& nest start",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "set PROGRAM_MODE=production&& nest start",
    "start:watch": "set PROGRAM_MODE=production&& nest start --watch",
    "start:dev": "set PROGRAM_MODE=development&& nest start",
    "dev": "set PROGRAM_MODE=development&& nest start --watch",
    "debug": "nest start --debug --watch",
    "docker:build": "docker build -f dockerfile -t bad-architecture .",
    "docker:dev": "docker run -e PROGRAM_MODE=development -p 8080:8080 bad-architecture",
    "docker:prod": "docker run -e PROGRAM_MODE=production -p 8080:8080 bad-architecture",
    "prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --config ./test/jest.config.js",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.config.js"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@sentry/nestjs": "^10.47.0",
    "bad-fockarch": "^3.0.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "fenviee": "^0.1.1",
    "fock-logger": "^6.3.2",
    "jsonwebtoken": "^9.0.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-oauth2": "^1.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "13.0.0"
  },
